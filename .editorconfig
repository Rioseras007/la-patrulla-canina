# EditorConfig es útil para mantener estándares de codificación consistentes
# para múltiples desarrolladores que trabajan en el mismo proyecto

# La propiedad "root" indica que este es el archivo EditorConfig raíz
root = true

# Configuración para todos los archivos
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf

# Configuración para archivos JavaScript
[*.js]
indent_style = space
indent_size = 4
max_line_length = 100

# Configuración para archivos HTML
[*.html]
indent_style = space
indent_size = 4

# Configuración para archivos CSS
[*.css]
indent_style = space
indent_size = 4

# Configuración para archivos JSON
[*.json]
indent_style = space
indent_size = 2
